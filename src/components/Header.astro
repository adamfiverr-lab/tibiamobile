---
import { MINIBIA_URL } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo" aria-label="Tibia Mobile Home">
			<span class="logo-text">Tibia<strong>Mobile</strong></span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/play">Play Now</HeaderLink>
			<HeaderLink href="/guide">Guide</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
		<a href={MINIBIA_URL} class="cta-button-header" target="_blank" rel="noopener">
			Play on Minibia
		</a>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(13, 15, 20, 0.95);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--border);
		padding: 0 1.5em;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
		height: 60px;
	}
	.logo {
		text-decoration: none;
		color: var(--text-heading);
	}
	.logo-text {
		font-size: 1.2em;
		letter-spacing: -0.02em;
	}
	.logo-text strong {
		color: var(--accent);
	}
	.nav-links {
		display: flex;
		gap: 0.25em;
	}
	.nav-links :global(a) {
		padding: 0.5em 0.75em;
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.9em;
		border-radius: 6px;
		transition: color 0.2s, background 0.2s;
	}
	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: var(--text-heading);
		background: rgba(200, 168, 78, 0.1);
	}
	@media (max-width: 720px) {
		.nav-links {
			display: none;
		}
		nav {
			padding: 0;
		}
	}
</style>
