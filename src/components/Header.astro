---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo" aria-label="Tibia Mobile Home">
			<span class="logo-text">Tibia<strong>Mobile</strong></span>
		</a>
		<div class="nav-links" id="nav-links">
			<HeaderLink href="/wiki">Wiki</HeaderLink>
			<HeaderLink href="/wiki/monsters">Monsters</HeaderLink>
			<HeaderLink href="/wiki/spells">Spells</HeaderLink>
			<HeaderLink href="/tools">Tools</HeaderLink>
			<HeaderLink href="/guide">Guide</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
		<button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
			<span></span>
			<span></span>
			<span></span>
		</button>
	</nav>
	<div class="header-border"></div>
</header>

<script>
	const hamburger = document.getElementById('hamburger');
	const navLinks = document.getElementById('nav-links');
	hamburger?.addEventListener('click', () => {
		const isOpen = navLinks?.classList.toggle('open');
		hamburger.setAttribute('aria-expanded', String(isOpen));
		hamburger.classList.toggle('active');
	});
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(26, 20, 16, 0.96);
		backdrop-filter: blur(10px);
		padding: 0 1.5em;
	}
	.header-border {
		height: 2px;
		background: linear-gradient(90deg, transparent, var(--accent-dark), var(--accent), var(--accent-dark), transparent);
		opacity: 0.4;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
		height: 56px;
	}
	.logo {
		text-decoration: none;
		color: var(--text-heading);
	}
	.logo-text {
		font-size: 1.15em;
		letter-spacing: -0.02em;
	}
	.logo-text strong {
		color: var(--accent);
	}
	.nav-links {
		display: flex;
		gap: 0.15em;
	}
	.nav-links :global(a) {
		padding: 0.4em 0.7em;
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.85em;
		border-radius: 3px;
		transition: color 0.2s, background 0.2s;
	}
	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: var(--text-heading);
		background: rgba(200, 168, 78, 0.08);
	}
	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 8px;
		z-index: 101;
	}
	.hamburger span {
		display: block;
		width: 22px;
		height: 2px;
		background: var(--text-muted);
		border-radius: 1px;
		transition: transform 0.3s, opacity 0.3s;
	}
	.hamburger.active span:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}
	.hamburger.active span:nth-child(2) {
		opacity: 0;
	}
	.hamburger.active span:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	@media (max-width: 720px) {
		.hamburger {
			display: flex;
		}
		.nav-links {
			display: none;
			position: absolute;
			top: 58px;
			left: 0;
			right: 0;
			background: rgba(26, 20, 16, 0.98);
			border-bottom: 1px solid var(--border);
			flex-direction: column;
			padding: 0.75em 1.5em 1em;
			gap: 0.15em;
		}
		.nav-links.open {
			display: flex;
		}
		.nav-links :global(a) {
			padding: 0.65em 0.75em;
			font-size: 0.95em;
		}
		nav {
			padding: 0;
		}
	}
</style>
