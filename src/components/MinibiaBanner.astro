---
const MINIBIA_URL = 'https://minibia.com';
---

<aside class="banner" id="minibia-banner">
	<div class="banner-inner">
		<div class="banner-content">
			<span class="banner-badge">Browser-Based</span>
			<p>
				<strong>Minibia</strong> — play classic Tibia directly in your browser. No downloads, works on mobile and desktop.
			</p>
		</div>
		<div class="banner-actions">
			<a href={MINIBIA_URL} class="banner-link" target="_blank" rel="noopener">Visit Minibia.com</a>
			<button class="banner-close" id="banner-close" aria-label="Dismiss banner">&times;</button>
		</div>
	</div>
</aside>

<script>
	const banner = document.getElementById('minibia-banner');
	const closeBtn = document.getElementById('banner-close');
	if (localStorage.getItem('minibia-banner-dismissed')) {
		banner?.remove();
	}
	closeBtn?.addEventListener('click', () => {
		banner?.remove();
		localStorage.setItem('minibia-banner-dismissed', '1');
	});
</script>

<style>
	.banner {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 10px;
		margin: 2em 0;
	}
	.banner-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1em 1.25em;
		gap: 1em;
	}
	.banner-content {
		display: flex;
		align-items: center;
		gap: 0.75em;
		min-width: 0;
	}
	.banner-content p {
		margin: 0;
		font-size: 0.9em;
		color: var(--text-muted);
	}
	.banner-content strong {
		color: var(--text-heading);
	}
	.banner-badge {
		flex-shrink: 0;
		font-size: 0.7em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--accent);
		background: rgba(200, 168, 78, 0.1);
		border: 1px solid rgba(200, 168, 78, 0.2);
		padding: 0.3em 0.6em;
		border-radius: 4px;
		white-space: nowrap;
	}
	.banner-actions {
		display: flex;
		align-items: center;
		gap: 0.75em;
		flex-shrink: 0;
	}
	.banner-link {
		font-size: 0.85em;
		font-weight: 600;
		color: var(--accent);
		white-space: nowrap;
	}
	.banner-link:hover {
		color: var(--accent-light);
	}
	.banner-close {
		background: none;
		border: none;
		color: var(--text-muted);
		font-size: 1.3em;
		cursor: pointer;
		padding: 0 0.25em;
		line-height: 1;
		opacity: 0.5;
		transition: opacity 0.2s;
	}
	.banner-close:hover {
		opacity: 1;
	}

	@media (max-width: 720px) {
		.banner-inner {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.75em;
		}
		.banner-actions {
			width: 100%;
			justify-content: space-between;
		}
	}
</style>
