---
import { MINIBIA_URL } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<span class="logo-text">Tibia<strong>Mobile</strong></span>
			<p>Your guide to playing Tibia on mobile devices. Powered by <a href={MINIBIA_URL} target="_blank" rel="noopener">Minibia</a>.</p>
		</div>
		<div class="footer-links">
			<h4>Content</h4>
			<a href="/play">Play Tibia Mobile</a>
			<a href="/guide">Beginner Guide</a>
			<a href="/blog">Blog</a>
		</div>
		<div class="footer-links">
			<h4>Play</h4>
			<a href={MINIBIA_URL} target="_blank" rel="noopener">Minibia.com</a>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} TibiaMobile.com &mdash; Not affiliated with CipSoft GmbH. Tibia is a registered trademark of CipSoft GmbH.</p>
	</div>
</footer>
<style>
	footer {
		border-top: 1px solid var(--border);
		background: var(--bg-card);
		padding: 3em 1.5em 1.5em;
		margin-top: 4em;
	}
	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 2em;
	}
	.footer-brand .logo-text {
		font-size: 1.2em;
		color: var(--text-heading);
	}
	.footer-brand .logo-text strong {
		color: var(--accent);
	}
	.footer-brand p {
		color: var(--text-muted);
		font-size: 0.9em;
		margin-top: 0.5em;
	}
	.footer-links {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
	}
	.footer-links h4 {
		color: var(--accent);
		font-size: 0.85em;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.5em;
	}
	.footer-links a {
		color: var(--text-muted);
		font-size: 0.9em;
	}
	.footer-links a:hover {
		color: var(--accent-light);
	}
	.footer-bottom {
		max-width: 1100px;
		margin: 2em auto 0;
		padding-top: 1.5em;
		border-top: 1px solid var(--border);
	}
	.footer-bottom p {
		color: var(--text-muted);
		font-size: 0.8em;
		text-align: center;
	}
	@media (max-width: 720px) {
		.footer-inner {
			grid-template-columns: 1fr;
			gap: 1.5em;
		}
	}
</style>
