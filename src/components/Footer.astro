---
const today = new Date();
---

<footer>
	<div class="footer-border"></div>
	<div class="footer-inner">
		<div class="footer-brand">
			<span class="logo-text">Tibia<strong>Mobile</strong></span>
			<p>A community resource for Tibia players. Guides, tools, and wiki content for the classic MMORPG.</p>
		</div>
		<div class="footer-links">
			<h4>Wiki</h4>
			<a href="/wiki/monsters">Monsters</a>
			<a href="/wiki/spells">Spells</a>
			<a href="/wiki/vocations">Vocations</a>
		</div>
		<div class="footer-links">
			<h4>Resources</h4>
			<a href="/tools">Tools</a>
			<a href="/guide">Beginner Guide</a>
			<a href="/blog">Blog</a>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} TibiaMobile.com &mdash; A fan site. Not affiliated with CipSoft GmbH. Tibia is a registered trademark of CipSoft GmbH.</p>
	</div>
</footer>
<style>
	footer {
		background: var(--bg-card);
		padding: 0 1.5em 1.5em;
		margin-top: 4em;
	}
	.footer-border {
		height: 2px;
		background: linear-gradient(90deg, transparent, var(--accent-dark), var(--accent), var(--accent-dark), transparent);
		opacity: 0.3;
		margin-bottom: 2.5em;
	}
	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 2em;
	}
	.footer-brand .logo-text {
		font-size: 1.15em;
		color: var(--text-heading);
	}
	.footer-brand .logo-text strong {
		color: var(--accent);
	}
	.footer-brand p {
		color: var(--text-muted);
		font-size: 0.85em;
		margin-top: 0.5em;
	}
	.footer-links {
		display: flex;
		flex-direction: column;
		gap: 0.35em;
	}
	.footer-links h4 {
		color: var(--accent-dark);
		font-size: 0.75em;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 0.5em;
	}
	.footer-links a {
		color: var(--text-muted);
		font-size: 0.85em;
	}
	.footer-links a:hover {
		color: var(--accent-light);
	}
	.footer-bottom {
		max-width: 1100px;
		margin: 2em auto 0;
		padding-top: 1.5em;
		border-top: 1px solid var(--border);
	}
	.footer-bottom p {
		color: var(--text-muted);
		font-size: 0.75em;
		text-align: center;
		opacity: 0.7;
	}
	@media (max-width: 720px) {
		.footer-inner {
			grid-template-columns: 1fr;
			gap: 1.5em;
		}
	}
</style>
