---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { MINIBIA_URL } from '../consts';

const title = 'About Tibia Mobile - Playing Tibia on Your Phone';
const description = 'TibiaMobile.com is your resource for playing the classic MMORPG Tibia on mobile devices via Minibia. Guides, tips, and everything Tibia Mobile.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<h1>About Tibia Mobile</h1>
			<p>
				<strong>TibiaMobile.com</strong> is a community resource dedicated to playing
				<a href="https://www.tibia.com" target="_blank" rel="noopener">Tibia</a> — one of the world's oldest
				and most iconic MMORPGs — on mobile devices.
			</p>
			<p>
				We provide guides, tips, hunting spot recommendations, vocation advice, and everything
				you need to enjoy Tibia on your phone or tablet through
				<a href={MINIBIA_URL} target="_blank" rel="noopener">Minibia</a>, the browser-based Tibia mobile client.
			</p>
			<h2>What is Minibia?</h2>
			<p>
				<a href={MINIBIA_URL} target="_blank" rel="noopener">Minibia</a> is a mobile-optimized Tibia client
				that runs directly in your web browser. No downloads, no app store — just visit Minibia.com and start playing
				the classic Tibia experience on any device.
			</p>
			<h2>Disclaimer</h2>
			<p>
				TibiaMobile.com is a fan site. Tibia is a registered trademark of
				<a href="https://www.cipsoft.com" target="_blank" rel="noopener">CipSoft GmbH</a>.
				This site is not affiliated with or endorsed by CipSoft.
			</p>
		</main>
		<Footer />
	</body>
</html>
