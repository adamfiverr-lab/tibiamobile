---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import monsters from '../data/monsters.json';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const monsterCount = monsters.length;
const popularMonsters = monsters.filter(m =>
	['dragon', 'demon', 'minotaur', 'cyclops', 'giant-spider', 'dragon-lord'].includes(m.slug)
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main>
			<!-- Intro - short and honest -->
			<section class="intro">
				<h1>Tibia<span class="highlight">Mobile</span></h1>
				<p>
					Community wiki, tools, and guides for the classic MMORPG Tibia.
					Everything you need to play — whether you're on desktop or mobile.
				</p>
			</section>

			<!-- Quick Links Grid - the hub -->
			<section class="hub-grid">
				<a href="/wiki/monsters" class="hub-card">
					<span class="hub-icon">&#x1F409;</span>
					<h2>Monster Database</h2>
					<p>{monsterCount} creatures with stats, loot, and weaknesses</p>
				</a>
				<a href="/wiki/spells" class="hub-card">
					<span class="hub-icon">&#x2728;</span>
					<h2>Spell List</h2>
					<p>All spells by vocation with mana costs and levels</p>
				</a>
				<a href="/tools" class="hub-card">
					<span class="hub-icon">&#x1F4CA;</span>
					<h2>Calculators</h2>
					<p>XP, damage, and skill training calculators</p>
				</a>
				<a href="/wiki/vocations" class="hub-card">
					<span class="hub-icon">&#x2694;</span>
					<h2>Vocations</h2>
					<p>Stats, strengths, and gear for every vocation</p>
				</a>
				<a href="/guide" class="hub-card">
					<span class="hub-icon">&#x1F4D6;</span>
					<h2>Beginner Guide</h2>
					<p>Getting started, controls, and first hunts</p>
				</a>
				<a href="/play" class="hub-card">
					<span class="hub-icon">&#x1F4F1;</span>
					<h2>Play on Mobile</h2>
					<p>How to play Tibia in your phone's browser</p>
				</a>
			</section>

			<!-- Popular Monsters - shows this is a real wiki -->
			<section class="content-section">
				<div class="section-header">
					<h2>Popular Monsters</h2>
					<a href="/wiki/monsters">View all {monsterCount} &rarr;</a>
				</div>
				<div class="monster-grid">
					{popularMonsters.map((m) => (
						<a href={`/wiki/monsters/${m.slug}`} class="card monster-card">
							<div class="monster-info">
								<h3>{m.name}</h3>
								<div class="monster-stats">
									<span class="stat">HP {m.hp.toLocaleString()}</span>
									<span class="stat">Exp {m.exp.toLocaleString()}</span>
								</div>
							</div>
						</a>
					))}
				</div>
			</section>

			<!-- Latest Posts -->
			<section class="content-section">
				<div class="section-header">
					<h2>Latest Guides</h2>
					<a href="/blog">View all &rarr;</a>
				</div>
				<div class="post-list">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-item">
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</a>
					))}
				</div>
			</section>

			<!-- FAQ - genuine answers, not a Minibia ad -->
			<section class="content-section">
				<h2>Frequently Asked Questions</h2>
				<div class="faq">
					<details>
						<summary>Can you play Tibia on mobile?</summary>
						<p>Yes. There are browser-based clients like <a href="https://minibia.com" target="_blank" rel="noopener">Minibia</a> that let you play Tibia in your phone's browser without downloading anything. See our <a href="/play">Play on Mobile</a> page for details.</p>
					</details>
					<details>
						<summary>What is the difference between Tibia and TibiaME?</summary>
						<p>TibiaME is a separate mobile game by CipSoft with a different world and simplified gameplay. It's not the same game as Tibia. If you want the original Tibia experience on mobile, you need a browser-based client. We have a <a href="/blog/tibia-vs-tibiame-whats-the-difference/">full comparison</a>.</p>
					</details>
					<details>
						<summary>What vocation should I pick?</summary>
						<p>It depends on your playstyle. Knights are tanky and beginner-friendly, Paladins are balanced ranged fighters, Sorcerers deal the most damage, and Druids are the best healers. See our <a href="/wiki/vocations">vocation guide</a> for full details.</p>
					</details>
					<details>
						<summary>Where should I hunt at level 30?</summary>
						<p><a href="/wiki/monsters/cyclops">Cyclopses</a> and <a href="/wiki/monsters/minotaur-guard">Minotaur Guards</a> are solid choices around level 30. Check our <a href="/blog/tibia-mobile-hunting-guide/">hunting guide</a> for recommendations at every level range.</p>
					</details>
					<details>
						<summary>How much experience do I need to reach level 100?</summary>
						<p>15,694,800 experience points. You can use our <a href="/tools/experience-calculator">XP calculator</a> to plan any level range.</p>
					</details>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	/* Intro */
	.intro {
		text-align: center;
		padding: 2em 0 1em;
	}
	.intro h1 {
		font-size: 2.5em;
		margin-bottom: 0.25em;
		letter-spacing: -0.02em;
	}
	.highlight {
		color: var(--accent);
	}
	.intro p {
		color: var(--text-muted);
		font-size: 1.1em;
		max-width: 500px;
		margin: 0 auto;
	}

	/* Hub Grid */
	.hub-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.75em;
		margin: 2em 0 3em;
	}
	.hub-card {
		display: block;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 10px;
		padding: 1.25em;
		text-decoration: none;
		transition: border-color 0.2s, background 0.2s;
	}
	.hub-card:hover {
		border-color: var(--accent);
		background: var(--bg-card-hover);
		text-decoration: none;
	}
	.hub-icon {
		font-size: 1.5em;
		display: block;
		margin-bottom: 0.4em;
	}
	.hub-card h2 {
		font-size: 1.05em;
		color: var(--text-heading);
		margin-bottom: 0.25em;
	}
	.hub-card p {
		font-size: 0.8em;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.4;
	}

	/* Section headers */
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 1em;
	}
	.section-header h2 {
		margin: 0;
	}
	.section-header a {
		font-size: 0.9em;
	}

	.content-section {
		margin-bottom: 3em;
	}
	.content-section > h2 {
		margin-bottom: 1em;
	}

	/* Monster grid */
	.monster-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.75em;
	}
	.monster-card {
		display: block;
		text-decoration: none;
		padding: 1em;
	}
	.monster-card h3 {
		font-size: 1em;
		color: var(--text-heading);
		margin-bottom: 0.4em;
	}
	.monster-stats {
		display: flex;
		gap: 0.75em;
	}
	.stat {
		font-size: 0.8em;
		color: var(--text-muted);
		background: rgba(200, 168, 78, 0.08);
		padding: 0.15em 0.5em;
		border-radius: 4px;
	}

	/* Post list */
	.post-list {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}
	.post-item {
		display: block;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 1em 1.25em;
		text-decoration: none;
		transition: border-color 0.2s;
	}
	.post-item:hover {
		border-color: var(--accent);
		text-decoration: none;
	}
	.post-item h3 {
		font-size: 1em;
		color: var(--text-heading);
		margin-bottom: 0.2em;
	}
	.post-item p {
		font-size: 0.85em;
		color: var(--text-muted);
		margin: 0;
	}

	/* FAQ */
	.faq {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}
	details {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 1em 1.25em;
	}
	details[open] {
		border-color: var(--accent);
	}
	summary {
		cursor: pointer;
		font-weight: 700;
		color: var(--text-heading);
		list-style: none;
	}
	summary::-webkit-details-marker {
		display: none;
	}
	summary::before {
		content: '+ ';
		color: var(--accent);
		font-weight: 700;
	}
	details[open] summary::before {
		content: '- ';
	}
	details p {
		margin-top: 0.75em;
		color: var(--text-muted);
	}

	@media (max-width: 720px) {
		.intro h1 { font-size: 2em; }
		.hub-grid { grid-template-columns: 1fr 1fr; }
		.monster-grid { grid-template-columns: 1fr 1fr; }
	}
	@media (max-width: 480px) {
		.hub-grid { grid-template-columns: 1fr; }
		.monster-grid { grid-template-columns: 1fr; }
	}
</style>
